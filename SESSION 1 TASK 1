import java.util.Scanner;

public class ATMMachine {

    public static void main(String[] args) {

        Scanner scanner = new Scanner(System.in);

        String userPin = "1234"; 
        double balance = 500.00;

        String selectedOperation = "";
        double transactionAmount = 0;


        int attempts = 3;
        boolean pinCorrect = false;
        String enteredPin;

        while (attempts > 0) {
            System.out.print("Enter your PIN: ");
            enteredPin = scanner.nextLine();

            if (enteredPin.equals(userPin)) {
                pinCorrect = true;
                System.out.println("PIN accepted.");
                break;
            } else {
                attempts--;
                if (attempts > 0) {
                    System.out.println("Wrong PIN, try again. Attempts left: " + attempts);
                } else {
                    System.out.println("Wrong PIN.");
                }
            }
        }

        if (!pinCorrect) {
            System.out.println("Too many wrong attempts, card blocked. Bye.");
            return; 
        }

        boolean running = true;
        String choice = "";

        while (running == true) {

            System.out.println();
            System.out.println("----------- MAIN MENU -----------");
            System.out.println("1. Withdraw");
            System.out.println("2. Deposit");
            System.out.println("3. Check Balance");
            System.out.println("4. Change PIN");
            System.out.println("5. Exit");
            System.out.print("Choose an option: ");

            choice = scanner.nextLine();

            if (choice.equals("1")) {

                selectedOperation = "WITHDRAW";
                System.out.print("How much do you want to withdraw? ");
                String amountStr = scanner.nextLine();
                double amount = 0;

                try {
                    amount = Double.parseDouble(amountStr);
                } catch (Exception e) {
                    System.out.println("That's not a valid number.");
                    continue; 
                }

                transactionAmount = amount;

                if (amount <= 0) {
                    System.out.println("Amount has to be more than 0!");
                } else if (amount > balance) {
                    System.out.println("You don't have enough money. Balance: " + balance);
                } else {
                    balance = balance - amount;
                    System.out.println("Here is your cash: " + amount);
                    System.out.println("Balance now: " + balance);
                }

            }
            else if (choice.equals("2")) {

                selectedOperation = "DEPOSIT";
                System.out.print("How much do you want to deposit? ");
                double amount = Double.parseDouble(scanner.nextLine());
                transactionAmount = amount;

                if (amount <= 0) {
                    System.out.println("Deposit amount must be greater than 0.");
                } else {
                    balance = balance + amount;
                    System.out.println("Deposit successful!");
                    System.out.println("Balance now: " + balance);
                }

            }
            else if (choice.equals("3")) {

                selectedOperation = "CHECK_BALANCE";
                System.out.println("Balance: " + balance);

            }
            else if (choice.equals("4")) {

                selectedOperation = "CHANGE_PIN";
                System.out.print("Confirm your current pin first: ");
                String checkPin = scanner.nextLine();

                if (checkPin.equals(userPin) == false) {
                    System.out.println("Pin is wrong, can't change it.");
                } else {
                    System.out.print("Ok, type your new 4 digit pin: ");
                    String newPin = scanner.nextLine();

                    if (newPin.length() == 4 && newPin.matches("[0-9][0-9][0-9][0-9]")) {
                        userPin = newPin;
                        System.out.println("Pin changed! don't forget it lol");
                    } else {
                        System.out.println("That's not 4 digits, pin not changed.");
                    }
                }

            }
            else if (choice.equals("5")) {
                running = false;
                System.out.println(" goodbye");
            }
            else {
                System.out.println("not option.");
            }

        } 

        scanner.close();


    }
}
