var pin = "1111";
var balance = 600;

var selectedOperation = "";
var transactionAmount = 0;

var tries = 3;
var correctPin = false;

while (tries > 0) {

    var enteredPin = prompt("Enter PIN");

    if (enteredPin == pin) {
        correctPin = true;
        console.log("PIN accepted");
        break;
    } else {
        tries--;

        if (tries > 0) {
            console.log("Wrong PIN");
        } else {
            console.log("Card blocked");
        }
    }
}

if (correctPin == true) {

    var run = true;

    while (run == true) {

        var choice = prompt(
            "1 Withdraw\n2 Deposit\n3 Check Balance\n4 Change PIN\n5 Exit"
        );

        if (choice == "1") {

            selectedOperation = "Withdraw";

            transactionAmount = Number(prompt("Enter amount"));

            if (transactionAmount <= 0) {
                console.log("Invalid amount");
            } else if (transactionAmount > balance) {
                console.log("Insufficient balance");
            } else {
                balance = balance - transactionAmount;
                console.log("Withdraw successful");
                console.log("Current Balance: " + balance);
            }

        } else if (choice == "2") {

            selectedOperation = "Deposit";

            transactionAmount = Number(prompt("Enter amount"));

            if (transactionAmount > 0) {
                balance = balance + transactionAmount;
                console.log("Deposit successful");
                console.log("Current Balance: " + balance);
            } else {
                console.log("Deposit amount must be greater than zero");
            }

        } else if (choice == "3") {

            selectedOperation = "Check Balance";

            console.log("Current Balance: " + balance);

        } else if (choice == "4") {

            selectedOperation = "Change PIN";

            var newPin = prompt("Enter new PIN");

            if (newPin.length == 4 && !isNaN(newPin)) {
                pin = newPin;
                console.log("PIN changed successfully");
            } else {
                console.log("PIN must contain exactly 4 digits");
            }

        } else if (choice == "5") {

            run = false;
            console.log("Thank you");

        } else {

            console.log("Invalid choice");

        }
    }
}

        scanner.close();


    }
