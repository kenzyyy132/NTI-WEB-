function processOrders(orders) {

    let totalRevenue = 0;
    let successfulOrders = 0;
    let processedOrders = 0;

    let skippedInRow = 0;
    let stockFailures = 0;

    let stopMessage = "";


    for (let i = 0; i < orders.length; i++) {

        let order = orders[i];
        processedOrders++;


        // Check skipped orders
        if (
            order.status === "cancelled" ||
            order.status === "invalid" ||
            order.stockAvailable === false
        ) {

            console.log("Skipped Order:", order.id);

            skippedInRow++;


            if (order.stockAvailable === false) {
                stockFailures++;
            }


            // Stop conditions
            if (skippedInRow === 3 || stockFailures === 3) {
                stopMessage = "System stopped due to critical failure";
                break;
            }

            continue;
        }


        // Process valid orders
        if (order.status === "valid" && order.stockAvailable === true) {

            console.log("Processing Order:", order.id);

            totalRevenue += order.amount;
            successfulOrders++;

            skippedInRow = 0;
        }
    }


    return {
        totalRevenue: totalRevenue,
        successfulOrders: successfulOrders,
        processedOrders: processedOrders,
        stopMessage: stopMessage
    };
}



// Testing

let orders = [
    {id: 1, status: "valid", stockAvailable: true, amount: 200},
    {id: 2, status: "cancelled", stockAvailable: true, amount: 100},
    {id: 3, status: "valid", stockAvailable: true, amount: 300},
    {id: 4, status: "invalid", stockAvailable: false, amount: 150},
    {id: 5, status: "valid", stockAvailable: true, amount: 500}
];


console.log(processOrders(orders));
